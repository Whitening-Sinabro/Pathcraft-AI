<Window x:Class="PathcraftAI.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:PathcraftAI.UI"
        xmlns:controls="clr-namespace:PathcraftAI.UI.Controls"
        Title="PathcraftAI - POE Build Search"
        Height="700" Width="1000"
        MinHeight="600" MinWidth="800"
        Background="#1E1E2E"
        Foreground="#CDD6F4">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ========== Color Definitions ========== -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#89B4FA"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="AccentColor" Color="#CBA6F7"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F9E2AF"/>
        <SolidColorBrush x:Key="DangerColor" Color="#F38BA8"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#262638"/>
        <SolidColorBrush x:Key="SurfaceDarkColor" Color="#181825"/>
        <SolidColorBrush x:Key="BorderColor" Color="#45475A"/>
        <SolidColorBrush x:Key="TextPrimaryColor" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="TextSecondaryColor" Color="#BAC2DE"/>
        <SolidColorBrush x:Key="TextMutedColor" Color="#7F849C"/>

        <!-- ========== Font Size Definitions (4단계) ========== -->
        <sys:Double x:Key="FontSizeHeaderLarge">24</sys:Double>
        <sys:Double x:Key="FontSizeHeaderMedium">16</sys:Double>
        <sys:Double x:Key="FontSizeBody">13</sys:Double>
        <sys:Double x:Key="FontSizeSmall">11</sys:Double>

        <!-- ========== Loading Spinner Style ========== -->
        <Style x:Key="LoadingSpinnerStyle" TargetType="Border">
            <Setter Property="Background" Value="#40000000"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <!-- ========== Section Expander Style ========== -->
        <Style x:Key="SectionExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <ToggleButton x:Name="HeaderToggle" Grid.Row="0"
                                              IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="HeaderBorder" Background="#313244" CornerRadius="8,8,0,0" Padding="16,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock x:Name="Arrow" Grid.Column="0" Text="▼" FontSize="10"
                                                               Foreground="{StaticResource TextMutedColor}"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <ContentPresenter Grid.Column="1" Content="{TemplateBinding Content}"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter TargetName="Arrow" Property="Text" Value="▶"/>
                                                    <Setter TargetName="HeaderBorder" Property="CornerRadius" Value="8"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HeaderBorder" Property="Background" Value="#3D3D52"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <ContentPresenter Content="{TemplateBinding Header}" RecognizesAccessKey="True"/>
                                </ToggleButton>

                                <!-- Content -->
                                <Border x:Name="ContentBorder" Grid.Row="1" Padding="16"
                                        Visibility="Visible">
                                    <ContentPresenter Content="{TemplateBinding Content}"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ContentBorder" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== Primary Button Style ========== -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#9DC4FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#7F849C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== Secondary Button Style ========== -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#1E1E2E"/>
                                <Setter Property="Foreground" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== Accent Button Style ========== -->
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D9BFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#7F849C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== Dark ComboBox Style ========== -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <ToggleButton Grid.Column="1"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <TextBlock Text="▼" FontSize="10" Foreground="{StaticResource TextMutedColor}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#313244" BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1" CornerRadius="6" Margin="0,4,0,0">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== Dark ComboBoxItem Style ========== -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#89B4FA"/>
                                <Setter Property="Foreground" Value="#1E1E2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== Dark TextBox Style ========== -->
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#6C7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SC/HC Toggle Button Style -->
        <Style x:Key="LeagueModeToggleStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7F849C"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#89B4FA"/>
                                <Setter Property="Foreground" Value="#1E1E2E"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Menu Bar -->
        <Border Grid.Row="0" Background="#181825" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PathcraftAI" FontSize="18" FontWeight="SemiBold"
                               Foreground="#89B4FA" VerticalAlignment="Center"/>

                    <!-- SC/HC Toggle -->
                    <Border Background="#313244" CornerRadius="4" Margin="16,0,0,0" Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="SCModeButton" Content="SC"
                                         GroupName="LeagueMode" IsChecked="True"
                                         Checked="LeagueMode_Changed"
                                         Style="{StaticResource LeagueModeToggleStyle}"/>
                            <RadioButton x:Name="HCModeButton" Content="HC"
                                         GroupName="LeagueMode"
                                         Checked="LeagueMode_Changed"
                                         Style="{StaticResource LeagueModeToggleStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ConnectPOEButton" Content="Connect POE Account"
                            Margin="0,0,8,0" Click="ConnectPOE_Click"
                            Background="#89B4FA" Foreground="#1E1E2E" Padding="12,6" BorderThickness="0"/>
                    <Button Content="POE Trade" Margin="0,0,8,0" Click="OpenTrade_Click"
                            Background="#F9E2AF" Foreground="#1E1E2E" Padding="12,6" BorderThickness="0"
                            ToolTip="POE Trade 검색 창 열기"/>
                    <Button Content="Bookmarks" Margin="0,0,8,0" Click="Bookmarks_Click"
                            Background="#A6E3A1" Foreground="#1E1E2E" Padding="12,6" BorderThickness="0"
                            ToolTip="저장된 빌드 북마크"/>
                    <Button Content="Settings" Margin="0,0,8,0" Click="Settings_Click"
                            Background="#313244" Foreground="#CDD6F4" Padding="12,6" BorderThickness="0"/>
                    <Button Content="Donate" Margin="0,0,8,0" Click="Donate_Click"
                            Background="#313244" Foreground="#CDD6F4" Padding="12,6" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content with Tabs -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="16"
                    Background="Transparent" BorderThickness="0"
                    SelectedIndex="1">

            <!-- Custom Tab Style -->
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#262638"/>
                    <Setter Property="Foreground" Value="#BAC2DE"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Background="{TemplateBinding Background}"
                                        CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}" Margin="0,0,4,0">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#89B4FA"/>
                                        <Setter Property="Foreground" Value="#1E1E2E"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#45475A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: Browse Builds -->
            <TabItem Header="🔍 Browse Builds">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Section -->
                    <Border Grid.Row="0" Background="#262638" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <!-- Filters Row -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Class Filter -->
                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="클래스" FontSize="11" Margin="0,0,0,4" Foreground="#BAC2DE"/>
                                    <ComboBox x:Name="ClassFilterCombo" Width="120" Height="28"
                                              Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                                              SelectionChanged="ClassFilter_SelectionChanged">
                                        <ComboBoxItem Content="All Classes" IsSelected="True"/>
                                        <ComboBoxItem Content="Witch"/>
                                        <ComboBoxItem Content="Shadow"/>
                                        <ComboBoxItem Content="Ranger"/>
                                        <ComboBoxItem Content="Duelist"/>
                                        <ComboBoxItem Content="Marauder"/>
                                        <ComboBoxItem Content="Templar"/>
                                        <ComboBoxItem Content="Scion"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Sort Filter -->
                                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                    <TextBlock Text="정렬" FontSize="11" Margin="0,0,0,4" Foreground="#BAC2DE"/>
                                    <ComboBox x:Name="SortFilterCombo" Width="130" Height="28"
                                              Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                                              SelectionChanged="SortFilter_SelectionChanged">
                                        <ComboBoxItem Content="조회수 높은순" IsSelected="True"/>
                                        <ComboBoxItem Content="최신순"/>
                                        <ComboBoxItem Content="좋아요순"/>
                                        <ComboBoxItem Content="가격 낮은순"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Budget Filter -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="예산 (Chaos)" FontSize="11" Margin="0,0,0,4" Foreground="#BAC2DE"/>
                                    <ComboBox x:Name="BudgetFilterCombo" Width="110" Height="28"
                                              Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                                              SelectionChanged="BudgetFilter_SelectionChanged">
                                        <ComboBoxItem Content="전체"/>
                                        <ComboBoxItem Content="~50c"/>
                                        <ComboBoxItem Content="~100c" IsSelected="True"/>
                                        <ComboBoxItem Content="~500c"/>
                                        <ComboBoxItem Content="~1000c"/>
                                        <ComboBoxItem Content="1000c+"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Search Row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="⭐ 스트리머/유튜버 검색" FontSize="12" Margin="0,0,0,4" Foreground="#F38BA8"/>
                                    <TextBox x:Name="StreamerInputBox"
                                             Height="32" Padding="8" FontSize="12"
                                             Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                                             Text="예: Zizaran, Steelmage, Pohx..."
                                             GotFocus="StreamerInputBox_GotFocus"/>
                                </StackPanel>

                                <Button Grid.Column="1" Content="🔍 검색" Height="32" Width="100"
                                        Margin="16,18,0,0" VerticalAlignment="Bottom"
                                        Background="#CBA6F7" Foreground="#1E1E2E" BorderThickness="0"
                                        Click="SearchBuilds_Click" FontWeight="SemiBold" FontSize="12"/>

                                <Button x:Name="RefreshButton" Grid.Column="2" Content="↻ 자동 추천" Height="32"
                                        Margin="8,18,0,0" Padding="12,0" VerticalAlignment="Bottom"
                                        Background="#89B4FA" Foreground="#1E1E2E" BorderThickness="0"
                                        Click="RefreshButton_Click" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Build Results -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="ResultsPanel" Orientation="Horizontal" ItemWidth="340" ItemHeight="Auto">
                            <StackPanel x:Name="PlaceholderPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,80,0,0">
                                <TextBlock x:Name="PlaceholderText"
                                           TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                                           FontSize="14" Foreground="#B0B0B0" Margin="0,0,0,24">
                                    <Run Text="🎯 " FontSize="32"/>
                                    <LineBreak/>
                                    <LineBreak/>
                                    <Run Text="스트리머 이름을 입력하고 검색하거나" FontSize="16" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                                    <LineBreak/>
                                    <Run Text="'자동 추천' 버튼을 클릭하세요!" FontSize="16" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                                </TextBlock>
                            </StackPanel>
                        </WrapPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 2: My Build -->
            <TabItem Header="📊 My Build">
                <Grid Margin="0,16,0,0">
                    <!-- Main Content -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- POB Input Section (Always Visible) -->
                            <Border Background="#262638" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="내 빌드 POB" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#89B4FA"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="POBInputBox" Grid.Column="0"
                                                     Style="{StaticResource DarkTextBoxStyle}"
                                                     Text="pobb.in URL 또는 POB 코드 붙여넣기"
                                                     GotFocus="POBInputBox_GotFocus"
                                                     ToolTip="pobb.in URL, pastebin URL 또는 POB 코드"/>
                                            <Button Grid.Column="1" Content="📁" Height="36" Width="36"
                                                    Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="0" FontSize="14"
                                                    Click="BrowsePOBFile_Click"
                                                    ToolTip="로컬 POB .xml 파일 열기"/>
                                        </Grid>
                                    </StackPanel>

                                    <Button x:Name="AnalyzeButton" Grid.Column="1" Content="분석" Height="36"
                                            Margin="16,22,0,0" VerticalAlignment="Bottom"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Click="AnalyzeMyBuild_Click"/>

                                    <Button x:Name="AIAnalysisButton" Grid.Column="2" Content="AI 분석" Height="36"
                                            Margin="8,22,0,0" VerticalAlignment="Bottom"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="AIAnalysis_Click"/>
                                </Grid>
                            </Border>

                            <!-- Empty State (Shown when no build analyzed) -->
                            <Border x:Name="EmptyStatePanel" Background="#262638" CornerRadius="8" Padding="48" Margin="0,0,0,12">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="빌드를 분석해보세요" FontSize="18" FontWeight="SemiBold"
                                               Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="POB 링크나 코드를 입력하고 '분석' 버튼을 클릭하세요.&#x0a;레벨링 가이드, 아이템 필터, 업그레이드 추천을 받을 수 있습니다."
                                               FontSize="13" Foreground="#7F849C" TextAlignment="Center"
                                               HorizontalAlignment="Center" LineHeight="22"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                                        <Border Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                                            <TextBlock FontSize="11" Foreground="#BAC2DE">
                                                <Run Text="1." FontWeight="SemiBold" Foreground="#89B4FA"/> POB 링크 입력
                                            </TextBlock>
                                        </Border>
                                        <Border Background="#313244" CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                                            <TextBlock FontSize="11" Foreground="#BAC2DE">
                                                <Run Text="2." FontWeight="SemiBold" Foreground="#A6E3A1"/> 분석 클릭
                                            </TextBlock>
                                        </Border>
                                        <Border Background="#313244" CornerRadius="6" Padding="12,8">
                                            <TextBlock FontSize="11" Foreground="#BAC2DE">
                                                <Run Text="3." FontWeight="SemiBold" Foreground="#CBA6F7"/> 결과 확인
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- League Info (Compact - Always Visible after analysis) -->
                            <Border x:Name="LeagueInfoBar" Background="#262638" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock x:Name="LeagueNameText" Text="League: Settlers"
                                                   FontSize="13" Foreground="#BAC2DE" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="DivineRateText" Text="1 div = 150c"
                                                   FontSize="13" Foreground="#F9E2AF" Margin="0,0,16,0" VerticalAlignment="Center"
                                                   Cursor="Hand" MouseEnter="DivineRateText_MouseEnter">
                                            <TextBlock.ToolTip>
                                                <ToolTip x:Name="DivineRateTooltip">
                                                    <TextBlock x:Name="DivineConversionText" Text="Loading..."/>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                        <TextBlock x:Name="POEAccountText" Text="Not connected"
                                                   FontSize="13" Foreground="#7F849C" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                x:Name="CharacterInfoPanel" Visibility="Collapsed">
                                        <TextBlock x:Name="MainCharacterText" Text="Character: -"
                                                   FontSize="13" Foreground="#BAC2DE" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Analysis Results Container (Shown after analysis) -->
                            <StackPanel x:Name="AnalysisResultsPanel" Visibility="Collapsed">

                                <!-- Build Overview Expander -->
                                <Expander x:Name="BuildOverviewExpander" Style="{StaticResource SectionExpanderStyle}" IsExpanded="True">
                                    <Expander.Header>
                                        <TextBlock Text="빌드 개요" FontSize="14" FontWeight="SemiBold" Foreground="#89B4FA"/>
                                    </Expander.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="BuildCharacterName" Text="Character: -"
                                                       FontSize="14" Foreground="#CDD6F4" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="BuildType" Text="Build Type: -"
                                                       FontSize="13" Foreground="#BAC2DE" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="BuildMainSkill" Text="Main Skill: -"
                                                       FontSize="13" Foreground="#BAC2DE"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="BuildUniqueCount" Text="Unique Items: 0"
                                                       FontSize="13" Foreground="#BAC2DE" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="BuildTotalValue" Text="Estimated Value: ~0c"
                                                       FontSize="13" Foreground="#F9E2AF"/>
                                        </StackPanel>
                                    </Grid>
                                </Expander>

                                <!-- Filter Generation Expander -->
                                <Expander x:Name="FilterGenerationExpander" Style="{StaticResource SectionExpanderStyle}" IsExpanded="False">
                                    <Expander.Header>
                                        <TextBlock Text="아이템 필터 생성" FontSize="14" FontWeight="SemiBold" Foreground="#F9E2AF"/>
                                    </Expander.Header>
                                    <StackPanel>
                                        <TextBlock Text="POB 빌드를 기반으로 진행 단계별 아이템 필터를 생성합니다."
                                                   FontSize="12" Foreground="#7F849C" Margin="0,0,0,16"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                <TextBlock Text="계정 이름" FontSize="11" Foreground="#7F849C" Margin="0,0,0,4"/>
                                                <TextBox x:Name="FilterAccountNameBox" Width="140"
                                                         Style="{StaticResource DarkTextBoxStyle}"
                                                         ToolTip="필터 파일명에 사용될 계정 이름"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                                <TextBlock Text="필터 단계" FontSize="11" Foreground="#7F849C" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="FilterPhaseComboBox" Width="120"
                                                          Style="{StaticResource DarkComboBoxStyle}">
                                                    <ComboBoxItem Content="All (전체)" IsSelected="True"/>
                                                    <ComboBoxItem Content="Leveling"/>
                                                    <ComboBoxItem Content="EarlyMap"/>
                                                    <ComboBoxItem Content="Endgame"/>
                                                    <ComboBoxItem Content="Uber"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                                <TextBlock Text="필터 테마" FontSize="11" Foreground="#7F849C" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="FilterThemeCombo" Width="140"
                                                          Style="{StaticResource DarkComboBoxStyle}"
                                                          SelectionChanged="FilterTheme_SelectionChanged">
                                                    <ComboBoxItem Content="Default (자동)" Tag="default" IsSelected="True"/>
                                                    <ComboBoxItem Content="Chaos DoT" Tag="chaos_dot"/>
                                                    <ComboBoxItem Content="Physical" Tag="physical"/>
                                                    <ComboBoxItem Content="Fire" Tag="fire"/>
                                                    <ComboBoxItem Content="Cold" Tag="cold"/>
                                                    <ComboBoxItem Content="Lightning" Tag="lightning"/>
                                                    <ComboBoxItem Content="Minion" Tag="minion"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <Button x:Name="GenerateFilterButton" Grid.Column="3" Content="필터 생성" Height="36"
                                                    VerticalAlignment="Bottom"
                                                    Background="#F9E2AF" Foreground="#1E1E2E"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="GenerateFilter_Click"/>
                                        </Grid>

                                        <!-- Filter Preview -->
                                        <Border Background="#1E1E2E" CornerRadius="6" Padding="8" Margin="0,16,0,0">
                                            <controls:FilterPreviewControl x:Name="FilterPreview" Height="200"/>
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <!-- Leveling Guide Expander -->
                                <Expander x:Name="LevelingGuideExpander" Style="{StaticResource SectionExpanderStyle}" IsExpanded="False">
                                    <Expander.Header>
                                        <TextBlock Text="레벨링 가이드" FontSize="14" FontWeight="SemiBold" Foreground="#A6E3A1"/>
                                    </Expander.Header>
                                    <StackPanel>
                                        <!-- Main Skill Info -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock x:Name="LevelingMainSkillText" Text="Main Skill: -"
                                                           FontSize="13" Foreground="#CDD6F4" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="LevelingTagsText" Text="Tags: -"
                                                           FontSize="12" Foreground="#BAC2DE" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <Button Grid.Column="1" x:Name="OpenYouTubeGuideButton" Content="YouTube 검색"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Background="#F38BA8" Foreground="#1E1E2E"
                                                    Click="OpenYouTubeGuide_Click"/>
                                        </Grid>

                                        <!-- Tips -->
                                        <TextBlock Text="Tips" FontSize="13" Foreground="#89B4FA" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ItemsControl x:Name="LevelingTipsList" Margin="0,0,0,16">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#BAC2DE"
                                                               Margin="8,2,0,2" TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Gem Progression -->
                                        <TextBlock Text="젬 진행" FontSize="13" Foreground="#89B4FA" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ItemsControl x:Name="GemProgressionList" Margin="0,0,0,16">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3,0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Level, StringFormat='Lv {0}'}"
                                                                   FontSize="12" Foreground="#F9E2AF" FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Gems}" FontSize="12" Foreground="#CDD6F4"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Leveling Gear -->
                                        <TextBlock Text="레벨링 장비" FontSize="13" Foreground="#89B4FA" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ItemsControl x:Name="LevelingGearList" Margin="0,0,0,16">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3,0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Level, StringFormat='Lv {0}'}"
                                                                   FontSize="12" Foreground="#F9E2AF" FontWeight="SemiBold"/>
                                                        <TextBlock Grid.Column="1" FontSize="12" Foreground="#CDD6F4">
                                                            <Run Text="{Binding Item, Mode=OneWay}"/>
                                                            <Run Text=" - " Foreground="#7F849C"/>
                                                            <Run Text="{Binding Reason, Mode=OneWay}" Foreground="#BAC2DE"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Ascendancy Order -->
                                        <TextBlock Text="승천 순서" FontSize="13" Foreground="#89B4FA" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ItemsControl x:Name="AscendancyOrderList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#CDD6F4" Margin="8,2,0,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander>

                                <!-- Build Comparison Expander -->
                                <Expander x:Name="BuildComparisonExpander" Style="{StaticResource SectionExpanderStyle}" IsExpanded="False">
                                    <Expander.Header>
                                        <TextBlock Text="빌드 비교 (Current vs Target)" FontSize="14" FontWeight="SemiBold" Foreground="#CBA6F7"/>
                                    </Expander.Header>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Comparison DataGrid -->
                                        <DataGrid x:Name="ComparisonGrid" Grid.Row="0"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="None"
                                                  Background="Transparent"
                                                  RowBackground="#313244"
                                                  AlternatingRowBackground="#262638"
                                                  BorderThickness="0"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  Margin="0,0,0,16">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Stat" Binding="{Binding Stat}" Width="*" FontWeight="SemiBold"/>
                                                <DataGridTextColumn Header="Current" Binding="{Binding CurrentDisplay}" Width="*" FontSize="13"/>
                                                <DataGridTextColumn Header="Target" Binding="{Binding TargetDisplay}" Width="*" FontSize="13"/>
                                                <DataGridTextColumn Header="Gap" Binding="{Binding GapDisplay}" Width="*" FontSize="13">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="warning">
                                                                    <Setter Property="Foreground" Value="#F9E2AF"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="ok">
                                                                    <Setter Property="Foreground" Value="#A6E3A1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <!-- Priority Upgrades -->
                                        <StackPanel x:Name="PriorityUpgradesPanel" Grid.Row="1" Visibility="Collapsed">
                                            <TextBlock Text="우선 업그레이드" FontSize="13" FontWeight="SemiBold"
                                                       Margin="0,0,0,8" Foreground="#89B4FA"/>
                                            <ItemsControl x:Name="PriorityUpgradesList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,8">
                                                            <TextBlock FontSize="12" Foreground="#CDD6F4" FontWeight="SemiBold">
                                                                <Run Text="{Binding Priority}"/>
                                                                <Run Text=". "/>
                                                                <Run Text="{Binding Description}"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding Suggestion}"
                                                                       FontSize="11" Foreground="#BAC2DE"
                                                                       Margin="16,2,0,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </Expander>

                                <!-- AI Analysis Expander -->
                                <Expander x:Name="AIAnalysisExpander" Style="{StaticResource SectionExpanderStyle}" IsExpanded="False">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="AI 빌드 분석" FontSize="14" FontWeight="SemiBold" Foreground="#CBA6F7"/>
                                            <TextBlock x:Name="AIProviderText" Text=" - Claude Sonnet"
                                                       FontSize="11" Foreground="#7F849C" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- AI Analysis Content -->
                                        <ScrollViewer Grid.Row="0" MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                                            <TextBlock x:Name="AIAnalysisText" TextWrapping="Wrap"
                                                       FontSize="13" Foreground="#CDD6F4" LineHeight="22"
                                                       Padding="12" Background="#181825"
                                                       Text="'AI 분석' 버튼을 클릭하여 빌드 인사이트를 받아보세요..."/>
                                        </ScrollViewer>

                                        <!-- AI Options -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                                            <ComboBox x:Name="AIProviderCombo" Width="180"
                                                      Style="{StaticResource DarkComboBoxStyle}"
                                                      Margin="0,0,8,0" SelectedIndex="0"
                                                      ToolTip="AI 분석 모드 선택"
                                                      SelectionChanged="AIProviderCombo_SelectionChanged">
                                                <ComboBoxItem Content="Auto (Best Available)" ToolTip="설정된 API 키 자동 감지. Settings에서 API 키 입력" IsSelected="True"/>
                                                <ComboBoxItem Content="Rule-Based (Free)" ToolTip="API 키 불필요. 빌드 테마/데미지 분석 기반 추천"/>
                                                <ComboBoxItem Content="Upgrade Guide" ToolTip="API 키 불필요. 단계별 업그레이드 경로 제안"/>
                                                <ComboBoxItem Content="Claude (Sonnet 3.5)" ToolTip="ANTHROPIC_API_KEY 필요. 심층 빌드 인사이트"/>
                                                <ComboBoxItem Content="GPT-4o (OpenAI)" ToolTip="OPENAI_API_KEY 필요. GPT-4o 기반 분석"/>
                                                <ComboBoxItem Content="Gemini (Google)" ToolTip="GOOGLE_API_KEY 필요. 무료 티어 제공"/>
                                                <ComboBoxItem Content="Grok (xAI)" ToolTip="XAI_API_KEY 필요. xAI Grok 기반 분석"/>
                                                <ComboBoxItem Content="Both (Compare)" ToolTip="Claude + GPT 결과 비교. 두 API 키 필요"/>
                                            </ComboBox>

                                            <Button Content="분석 실행" Style="{StaticResource AccentButtonStyle}"
                                                    Click="AIAnalysis_Click" Margin="0,0,8,0"/>

                                            <Button Content="복사" Style="{StaticResource SecondaryButtonStyle}"
                                                    Click="CopyAIAnalysis_Click"/>

                                            <TextBlock x:Name="APIKeyStatusText" Text=""
                                                       FontSize="11" Foreground="#7F849C" VerticalAlignment="Center" Margin="16,0,0,0"/>

                                            <TextBlock x:Name="AITokensText" Text="Tokens: 0 / 0"
                                                       FontSize="11" Foreground="#7F849C" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Expander>

                                <!-- Upgrade Path Expander -->
                                <Expander x:Name="UpgradePathExpander" Style="{StaticResource SectionExpanderStyle}" IsExpanded="False">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="업그레이드 경로" FontSize="14" FontWeight="SemiBold" Foreground="#89B4FA"/>
                                            <TextBlock x:Name="UpgradeBudgetText" Text=" - Budget: 100c"
                                                       FontSize="11" Foreground="#F9E2AF" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <StackPanel>
                                        <TextBlock x:Name="UpgradePathDescription"
                                                   Text="현재 빌드와 목표 POB를 기반으로 한 업그레이드 경로입니다."
                                                   FontSize="12" Foreground="#BAC2DE" Margin="0,0,0,16"/>

                                        <!-- Upgrade Suggestions -->
                                        <ItemsControl x:Name="UpgradesList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#313244" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" FontSize="12" Foreground="#BAC2DE" VerticalAlignment="Center">
                                                                <Run Text="• "/>
                                                                <Run Text="{Binding ItemName, Mode=OneWay}" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                                                                <Run Text=" (~"/>
                                                                <Run Text="{Binding ChaosValue, Mode=OneWay, StringFormat=F0}"/>
                                                                <Run Text="c): "/>
                                                                <Run Text="{Binding Reason, Mode=OneWay}"/>
                                                            </TextBlock>
                                                            <Button Grid.Column="1" Content="Trade"
                                                                    Click="OpenTradeUrl_Click"
                                                                    Tag="{Binding TradeUrl}"
                                                                    Visibility="{Binding HasTradeUrl, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                    Padding="12,6" FontSize="11"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander>

                                <!-- Passive Tree Expander -->
                                <Expander x:Name="PassiveTreeExpander" Style="{StaticResource SectionExpanderStyle}" IsExpanded="False"
                                          Background="#1E2A32">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="패시브 트리 로드맵" FontSize="14" FontWeight="SemiBold" Foreground="#8AC4F8"/>
                                            <TextBlock x:Name="PassivePointsText" Text=" - 27 points needed"
                                                       FontSize="11" Foreground="#7F849C" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock x:Name="PassiveCurrentLevelText" Grid.Column="0" Text="Lv69"
                                                       FontSize="13" Foreground="#FFD700" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text=" → " FontSize="13" Foreground="#7F849C"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                            <TextBlock x:Name="PassiveTargetLevelText" Grid.Column="2" Text="Lv94"
                                                       FontSize="13" Foreground="#8AC4F8" VerticalAlignment="Center"/>
                                        </Grid>

                                        <ItemsControl x:Name="PassiveRoadmapList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1A2530" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Border Grid.Column="0" Background="#33648C" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                                                    <TextBlock Text="{Binding LevelRange}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                                </Border>

                                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" Foreground="#BAC2DE">
                                                                    <Run Text="Focus: "/>
                                                                    <Run Text="{Binding PriorityFocus}" FontWeight="SemiBold" Foreground="#8AC4F8"/>
                                                                </TextBlock>

                                                                <TextBlock Grid.Column="2" FontSize="12" Foreground="#FFD700" VerticalAlignment="Center">
                                                                    <Run Text="{Binding Points}"/> points
                                                                </TextBlock>
                                                            </Grid>

                                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Nodes}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock FontSize="11" Foreground="#CDD6F4" Margin="0,2,0,2">
                                                                            <Run Text="→ "/>
                                                                            <Run Text="{Binding Name}" FontWeight="SemiBold"/>
                                                                            <Run Text=" " />
                                                                            <Run Text="{Binding TypeDisplay}" Foreground="#FFA500"/>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander>

                                <!-- Farming Strategy Expander -->
                                <Expander x:Name="FarmingStrategyExpander" Style="{StaticResource SectionExpanderStyle}" IsExpanded="False">
                                    <Expander.Header>
                                        <TextBlock Text="파밍 전략 추천" FontSize="14" FontWeight="SemiBold" Foreground="#F9E2AF"/>
                                    </Expander.Header>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <TextBlock Text="빌드 태그: " FontSize="12" Foreground="#BAC2DE" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="FarmingBuildTagsText" Text="-" FontSize="12" Foreground="#89B4FA" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <ItemsControl x:Name="FarmingStrategiesList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#313244" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                    <Border Background="#45475A" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                                                        <TextBlock Text="{Binding InvestmentDisplay}" FontSize="10" Foreground="#BAC2DE"/>
                                                                    </Border>
                                                                    <Border Background="#A6E3A1" CornerRadius="4" Padding="8,4">
                                                                        <TextBlock Text="{Binding ReturnsDisplay}" FontSize="10" Foreground="#1E1E2E" FontWeight="SemiBold"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Grid>

                                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#BAC2DE" Margin="0,0,0,8"/>

                                                            <TextBlock Text="추천 맵:" FontSize="11" Foreground="#89B4FA" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                            <ItemsControl ItemsSource="{Binding Maps}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock FontSize="11" Foreground="#CDD6F4" Margin="8,2,0,2">
                                                                            <Run Text="• "/>
                                                                            <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold"/>
                                                                            <Run Text=" (T"/>
                                                                            <Run Text="{Binding Tier, Mode=OneWay}"/>
                                                                            <Run Text=")"/>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="일반 팁:" FontSize="12" Foreground="#89B4FA" FontWeight="SemiBold" Margin="0,8,0,8"/>
                                        <ItemsControl x:Name="FarmingGeneralTipsList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="#BAC2DE" Margin="8,2,0,2" TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Expander>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Loading Overlay -->
                    <Border x:Name="LoadingOverlay" Background="#CC1E1E2E" Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="48" Height="48" CornerRadius="24" Background="#313244" Margin="0,0,0,16">
                                <TextBlock Text="⏳" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="LoadingRotation" CenterX="12" CenterY="12"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                            <TextBlock x:Name="LoadingText" Text="분석 중..." FontSize="14" Foreground="#CDD6F4" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="LoadingSubText" Text="" FontSize="11" Foreground="#7F849C" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
